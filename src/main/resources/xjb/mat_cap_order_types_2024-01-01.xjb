<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<jaxb:bindings
        version="2.1"
        xmlns:jaxb="http://java.sun.com/xml/ns/jaxb"
        xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <jaxb:bindings schemaLocation="../xsd/mat_cap_order_types_2024-01-01.xsd" node="//xs:schema">
        <jaxb:schemaBindings>
            <jaxb:package name="ru.vtb.msa.smkp.model.external.pf.mat_cap_order_types._2024_01_01"/>
        </jaxb:schemaBindings>
        <jaxb:bindings node="xs:complexType[@name='ТипНаправлениеРаспоряженияМСК']">
            <jaxb:class name="MaternalFamilyCapitalUsingDirectionType"/>
            <jaxb:bindings node="xs:sequence/xs:element[@name='КатегорияНаправления']">
                <jaxb:property name="usingDirectionCategory"/>
            </jaxb:bindings>
            <jaxb:bindings node="xs:sequence/xs:element[@name='КатегорияНаправления']/xs:simpleType">
                <jaxb:typesafeEnumClass name="UsingDirectionCategory">
                    <jaxb:typesafeEnumMember value="УЖУ" name="HOUSING_IMPROVEMENT"/>
                    <jaxb:typesafeEnumMember value="ОБРАЗОВАНИЕ" name="EDUCATION"/>
                    <jaxb:typesafeEnumMember value="НП" name="ACCUMULATED_PENSION"/>
                    <jaxb:typesafeEnumMember value="САДИ" name="CHILD_SOCIAL_ADAPTATION"/>
                    <jaxb:typesafeEnumMember value="ОСТАТОК" name="REMAINDER_LUMP_SUM"/>
