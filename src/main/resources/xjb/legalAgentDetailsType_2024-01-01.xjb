<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<jaxb:bindings
        version="2.1"
        xmlns:jaxb="http://java.sun.com/xml/ns/jaxb"
        xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <jaxb:bindings schemaLocation="../xsd/legalAgentDetailsType_2024-01-01.xsd" node="//xs:schema">
        <jaxb:schemaBindings>
            <jaxb:package name="ru.vtb.msa.smkp.model.external.pf.legal_agent_details_type._2024_01_01"/>
        </jaxb:schemaBindings>

        <!-- ТипПредставитель_ЮЛ_ФЛ -->
        <jaxb:bindings node="xs:complexType[@name='ТипПредставитель_ЮЛ_ФЛ']">
            <jaxb:class name="LegalAgentJuridicalPersonPhysicalPersonType"/>
            <jaxb:bindings node="xs:sequence/xs:element[@name='АнкетныеДанные']">
                <jaxb:property name="personalData"/>
                <jaxb:bindings node="xs:complexType">
                    <jaxb:class name="PersonalData"/>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:ФИО']">
                        <jaxb:property name="fullName"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:СНИЛС']">
                        <jaxb:property name="individualInsuranceNumber"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Гражданство']">
                        <jaxb:property name="citizenship"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:АдресРФ']">
                        <jaxb:property name="russianAddress"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Телефон']">
                        <jaxb:property name="phone"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:АдресЭлПочты']">
                        <jaxb:property name="emailAddress"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:УдостоверяющийДокумент']">
                        <jaxb:property name="identityDocument"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:МестоРождения']">
                        <jaxb:property name="birthPlace"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Пол']">
                        <jaxb:property name="gender"/>
                    </jaxb:bindings>
                </jaxb:bindings>
            </jaxb:bindings>
            <jaxb:bindings node="xs:sequence/xs:element[@name='Тип']">
                <jaxb:property name="agentType"/>
                <jaxb:bindings node="xs:complexType">
                    <jaxb:class name="AgentType"/>
                    <jaxb:bindings node="xs:choice/xs:element[@name='ЗаконныйПР']">
                        <jaxb:property name="legalRepresentative"/>
                        <jaxb:bindings node="xs:simpleType">
                            <jaxb:typesafeEnumClass name="LegalRepresentativeType">
                                <jaxb:typesafeEnumMember value="1" name="PARENT"/>
                                <jaxb:typesafeEnumMember value="2" name="GUARDIAN"/>
                                <jaxb:typesafeEnumMember value="3" name="CURATOR"/>
                            </jaxb:typesafeEnumClass>
                        </jaxb:bindings>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:choice/xs:element[@name='ДоверенноеЛицо']">
                        <jaxb:property name="authorizedPerson"/>
                    </jaxb:bindings>
                </jaxb:bindings>
            </jaxb:bindings>
            <jaxb:bindings node="xs:sequence/xs:element[@name='ЮридическоеЛицо']">
                <jaxb:property name="juridicalPerson"/>
                <jaxb:bindings node="xs:complexType">
                    <jaxb:class name="JuridicalPerson"/>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Наименование']">
                        <jaxb:property name="name"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:ЮрАдрес']">
                        <jaxb:property name="legalAddress"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:ИНН']">
                        <jaxb:property name="inn"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:КПП']">
                        <jaxb:property name="kpp"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@name='Адрес']">
                        <jaxb:property name="address"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Телефон']">
                        <jaxb:property name="phone"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:АдресЭлПочты']">
                        <jaxb:property name="emailAddress"/>
                    </jaxb:bindings>
                </jaxb:bindings>
            </jaxb:bindings>
            <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:ДокументПодтверждающийПолномочия']">
                <jaxb:property name="authorityConfirmingDocument"/>
            </jaxb:bindings>
        </jaxb:bindings>

        <!-- ТипПредставитель_ФЛ -->
        <jaxb:bindings node="xs:complexType[@name='ТипПредставитель_ФЛ']">
            <jaxb:class name="LegalAgentPhysicalPersonType"/>
            <jaxb:bindings node="xs:sequence/xs:element[@name='АнкетныеДанные']">
                <jaxb:property name="personalData"/>
                <jaxb:bindings node="xs:complexType">
                    <jaxb:class name="PersonalData"/>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:ФИО']">
                        <jaxb:property name="fullName"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:СНИЛС']">
                        <jaxb:property name="individualInsuranceNumber"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Гражданство']">
                        <jaxb:property name="citizenship"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:АдресРФ']">
                        <jaxb:property name="russianAddress"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Телефон']">
                        <jaxb:property name="phone"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:АдресЭлПочты']">
                        <jaxb:property name="emailAddress"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:УдостоверяющийДокумент']">
                        <jaxb:property name="identityDocument"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:МестоРождения']">
                        <jaxb:property name="birthPlace"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Пол']">
                        <jaxb:property name="gender"/>
                    </jaxb:bindings>
                </jaxb:bindings>
            </jaxb:bindings>
            <jaxb:bindings node="xs:sequence/xs:element[@name='Тип']">
                <jaxb:property name="agentType"/>
                <jaxb:bindings node="xs:complexType">
                    <jaxb:class name="AgentType"/>
                    <jaxb:bindings node="xs:choice/xs:element[@name='ЗаконныйПР']">
                        <jaxb:property name="legalRepresentative"/>
                        <jaxb:bindings node="xs:simpleType">
                            <jaxb:typesafeEnumClass name="LegalRepresentativeType">
                                <jaxb:typesafeEnumMember value="1" name="PARENT"/>
                                <jaxb:typesafeEnumMember value="2" name="GUARDIAN"/>
                                <jaxb:typesafeEnumMember value="3" name="CURATOR"/>
                            </jaxb:typesafeEnumClass>
                        </jaxb:bindings>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:choice/xs:element[@name='ДоверенноеЛицо']">
                        <jaxb:property name="authorizedPerson"/>
                    </jaxb:bindings>
                </jaxb:bindings>
            </jaxb:bindings>
            <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:ДокументПодтверждающийПолномочия']">
                <jaxb:property name="authorityConfirmingDocument"/>
            </jaxb:bindings>
        </jaxb:bindings>

        <!-- ТипПредставитель_ГС -->
        <jaxb:bindings node="xs:complexType[@name='ТипПредставитель_ГС']">
            <jaxb:class name="LegalAgentStateServiceType"/>
            <jaxb:bindings node="xs:sequence/xs:element[@name='АнкетныеДанные']">
                <jaxb:property name="personalData"/>
                <jaxb:bindings node="xs:complexType">
                    <jaxb:class name="PersonalData"/>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:ФИО']">
                        <jaxb:property name="fullName"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:СНИЛС']">
                        <jaxb:property name="individualInsuranceNumber"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Гражданство']">
                        <jaxb:property name="citizenship"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:АдресРФ']">
                        <jaxb:property name="russianAddress"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Телефон']">
                        <jaxb:property name="phone"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:АдресЭлПочты']">
                        <jaxb:property name="emailAddress"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:УдостоверяющийДокумент']">
                        <jaxb:property name="identityDocument"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:МестоРождения']">
                        <jaxb:property name="birthPlace"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Пол']">
                        <jaxb:property name="gender"/>
                    </jaxb:bindings>
                </jaxb:bindings>
            </jaxb:bindings>
            <jaxb:bindings node="xs:sequence/xs:element[@name='Тип']">
                <jaxb:property name="agentType"/>
                <jaxb:bindings node="xs:complexType">
                    <jaxb:class name="AgentType"/>
                    <jaxb:bindings node="xs:choice/xs:element[@name='ЗаконныйПР']">
                        <jaxb:property name="legalRepresentative"/>
                        <jaxb:bindings node="xs:simpleType">
                            <jaxb:typesafeEnumClass name="LegalRepresentativeType">
                                <jaxb:typesafeEnumMember value="1" name="PARENT"/>
                                <jaxb:typesafeEnumMember value="2" name="GUARDIAN"/>
                                <jaxb:typesafeEnumMember value="3" name="CURATOR"/>
                            </jaxb:typesafeEnumClass>
                        </jaxb:bindings>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:choice/xs:element[@name='ДоверенноеЛицо']">
                        <jaxb:property name="authorizedPerson"/>
                    </jaxb:bindings>
                </jaxb:bindings>
            </jaxb:bindings>
            <jaxb:bindings node="xs:sequence/xs:element[@name='ЮридическоеЛицо']">
                <jaxb:property name="juridicalPerson"/>
                <jaxb:bindings node="xs:complexType">
                    <jaxb:class name="JuridicalPerson"/>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Наименование']">
                        <jaxb:property name="name"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:ЮрАдрес']">
                        <jaxb:property name="legalAddress"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:ИНН']">
                        <jaxb:property name="inn"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:КПП']">
                        <jaxb:property name="kpp"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@name='Адрес']">
                        <jaxb:property name="address"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:Телефон']">
                        <jaxb:property name="phone"/>
                    </jaxb:bindings>
                    <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:АдресЭлПочты']">
                        <jaxb:property name="emailAddress"/>
                    </jaxb:bindings>
                </jaxb:bindings>
            </jaxb:bindings>
            <jaxb:bindings node="xs:sequence/xs:element[@ref='УТ7:ДокументПодтверждающийПолномочия']">
                <jaxb:property name="authorityConfirmingDocument"/>
            </jaxb:bindings>
        </jaxb:bindings>
    </jaxb:bindings>
</jaxb:bindings>

