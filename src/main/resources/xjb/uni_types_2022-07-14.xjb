                <jaxb:bindings node="xs:element[@name='Ознакомлен']">
                    <jaxb:property name="reviewed"/>
                </jaxb:bindings>
            </jaxb:bindings>
        </jaxb:bindings>

        <jaxb:bindings node="xs:group[@name='ГрПрилагаемыйДокумент']">
            <jaxb:bindings node="xs:sequence">
                <jaxb:bindings node="xs:element[@name='Реквизиты']">
                    <jaxb:property name="documentRequisites"/>
                    <jaxb:bindings node="xs:complexType">
                        <jaxb:class name="DocumentRequisites"/>
                        <jaxb:bindings node="xs:sequence">
                            <jaxb:bindings node="xs:element[@name='Реквизит']">
                                <jaxb:property name="requisite"/>
                                <jaxb:bindings node="xs:complexType">
                                    <jaxb:class name="Requisite"/>
                                    <jaxb:bindings node="xs:sequence">
                                        <jaxb:bindings node="xs:element[@name='Значение']">
                                            <jaxb:property name="requisiteValue"/>
                                        </jaxb:bindings>
                                    </jaxb:bindings>
                                </jaxb:bindings>
                            </jaxb:bindings>
                        </jaxb:bindings>
                    </jaxb:bindings>
                </jaxb:bindings>
                <jaxb:bindings node="xs:element[@name='ПредставленностьДокумента']">
                    <jaxb:property name="documentCopiesNumber"/>
                </jaxb:bindings>
            </jaxb:bindings>
        </jaxb:bindings>

        <jaxb:bindings node="xs:complexType[@name='ТипПрилагаемыйДокументНумерованный']">
            <jaxb:class name="NumberedAdditionalDocumentDetailsType"/>
            <jaxb:bindings node="xs:sequence">
                <jaxb:bindings node="xs:element[@name='НомерПП']">
                    <jaxb:property name="stringNumber"/>
                </jaxb:bindings>
            </jaxb:bindings>
        </jaxb:bindings>

        <jaxb:bindings node="xs:complexType[@name='ТипПрилагаемыйДокумент']">
            <jaxb:class name="AdditionalDocumentDetailsType"/>
        </jaxb:bindings>

        <jaxb:bindings node="xs:complexType[@name='ТипПрилагаемыеДокументы']">
            <jaxb:class name="additionalDocumentsDetailsType"/>
            <jaxb:bindings node="xs:sequence">
                <jaxb:bindings node="xs:element[@name='ПрилагаемыйДокумент']">
                    <jaxb:property name="additionalDocument"/>
                </jaxb:bindings>
            </jaxb:bindings>
        </jaxb:bindings>

        <jaxb:bindings node="xs:group[@name='ГрДолжностноеЛицо']">
            <jaxb:bindings node="xs:sequence">
                <jaxb:bindings node="xs:element[@name='ФИО']">
                    <jaxb:property name="fullName"/>
                </jaxb:bindings>
                <jaxb:bindings node="xs:element[@name='Должность']">
                    <jaxb:property name="post"/>
                </jaxb:bindings>
            </jaxb:bindings>
        </jaxb:bindings>

        <jaxb:bindings node="xs:complexType[@name='ТипДолжностноеЛицо']">
            <jaxb:class name="officialPersonType"/>
        </jaxb:bindings>

        <jaxb:bindings node="xs:complexType[@name='ТипКонтактноеДолжностноеЛицо']">
            <jaxb:class name="ContactOfficialPersonType"/>
            <jaxb:bindings node="xs:sequence">
                <jaxb:bindings node="xs:element[@name='Телефон']">
                    <jaxb:property name="phoneNumber"/>
                </jaxb:bindings>
            </jaxb:bindings>
        </jaxb:bindings>

        <jaxb:bindings node="xs:complexType[@name='ТипОрганизацияПФР']">
            <jaxb:class name="PensionFundDetailsType"/>
        </jaxb:bindings>

        <jaxb:bindings node="xs:complexType[@name='ТипСведенияТОПФР']">
            <jaxb:class name="TerritorialPensionFundDetailsType"/>
            <jaxb:bindings node="xs:sequence">
                <jaxb:bindings node="xs:element[@name='Код']">
                    <jaxb:property name="code"/>
                </jaxb:bindings>
            </jaxb:bindings>
        </jaxb:bindings>

        <jaxb:bindings node="xs:complexType[@name='ТипТОПФР']">
            <jaxb:class name="TerritorialPensionFundShortDetailsType"/>
            <jaxb:bindings node="xs:sequence">
                <jaxb:bindings node="xs:element[@name='Код']">
                    <jaxb:property name="code"/>
                </jaxb:bindings>
            </jaxb:bindings>
        </jaxb:bindings>

        <jaxb:bindings node="xs:complexType[@name='ТипТОПФРсАдресом']">
            <jaxb:class name="TerritorialPensionFundFullDetailsType"/>
            <jaxb:bindings node="xs:sequence">
                <jaxb:bindings node="xs:element[@name='Код']">
                    <jaxb:property name="code"/>
                </jaxb:bindings>
            </jaxb:bindings>
        </jaxb:bindings>


    </jaxb:bindings>
</jaxb:bindings>