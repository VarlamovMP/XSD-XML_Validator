                <jaxb:bindings node="xs:element[@name='По']">
                    <jaxb:property name="to"/>
                </jaxb:bindings>
            </jaxb:bindings>
        </jaxb:bindings>

        <jaxb:bindings node="xs:complexType[@name='ТипРеквизитыДокумента']">
