                <jaxb:typesafeEnumMember value="ПАСПОРТ МОРЯКА" name="SEAMAN_PASSPORT"/>
                <jaxb:typesafeEnumMember value="ЗГПАСПОРТ" name="INTERNATIONAL_PASSPORT"/>
                <jaxb:typesafeEnumMember value="ИНПАСПОРТ" name="FOREIGN_PASSPORT"/>
                <jaxb:typesafeEnumMember value="ЗГПАСПОРТ РФ" name="RUSSIAN_INTERNATIONAL_PASSPORT"/>
                <jaxb:typesafeEnumMember value="СЛУЖ ПАСПОРТ" name="SERVICE_PASSPORT"/>
                <jaxb:typesafeEnumMember value="ВРЕМ УДОСТ" name="INTERIM_CERTIFICATE"/>
                <jaxb:typesafeEnumMember value="ВОЕН БИЛЕТ ОЗ" name="RESERVE_OFFICER_MILITARY_ID_CARD"/>
                <jaxb:typesafeEnumMember value="УДОСТ ОФИЦЕРА" name="OFFICER_CERTIFICATE"/>
                <jaxb:typesafeEnumMember value="ВРУДВБ" name="TEMPORARY_MILITARY_ID_CARD"/>
                <jaxb:typesafeEnumMember value="РАЗРВР" name="TEMPORARY_RESIDENCE_PERMIT"/>
                <jaxb:typesafeEnumMember value="СВВРУБ" name="TEMPORARY_ASYLUM_CERTIFICATE"/>
                <jaxb:typesafeEnumMember value="СВРЖИН" name="BIRTH_CERTIFICATE_FOREIGN"/>
                <jaxb:typesafeEnumMember value="ПРОЧЕЕ" name="OTHER"/>
            </jaxb:typesafeEnumClass>
