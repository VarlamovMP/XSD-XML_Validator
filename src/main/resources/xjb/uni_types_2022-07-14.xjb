        <jaxb:bindings node="xs:simpleType[@name='ТипТипУД']">
            <jaxb:typesafeEnumClass name="IdentityDocumentType">
                <jaxb:typesafeEnumMember value="ПАСПОРТ" name="PASSPORT"/>
                <jaxb:typesafeEnumMember value="ПАСПОРТ РОССИИ" name="RUSSIAN_PASSPORT"/>
                <jaxb:typesafeEnumMember value="СВИД О РОЖД" name="BIRTH_CERTIFICATE"/>
